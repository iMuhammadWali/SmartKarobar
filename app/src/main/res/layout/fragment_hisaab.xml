<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HisaabFragment"
    android:orientation="vertical"
    android:background="#E9F5EF">

    <LinearLayout
        android:id="@+id/topNavbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="#1F5E46">

        <ImageView
            android:id="@+id/ivProfileTop"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_profile_avatar"
            android:background="@drawable/bg_rounded_light_green"
            android:padding="2dp"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tvTopTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Hisaab"
            android:textColor="#E8F5EE"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivSearch"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:tint="#D8F3DC" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Sab (All)"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_nav_selected" />

                <TextView
                    android:id="@+id/chipSales"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Bikri (Sales)"
                    android:textColor="#2D6A4F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_rounded_light_green" />

                <TextView
                    android:id="@+id/chipKharcha"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Kharcha (Expense)"
                    android:textColor="#2D6A4F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_rounded_light_green" />

                <TextView
                    android:id="@+id/chipUdhaar"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Udhaar (depters)"
                    android:textColor="#2D6A4F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_rounded_light_green" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Section Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aaj ki Tafseel"
                android:textColor="#2F3740"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTransactionsCount"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginStart="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:gravity="center"
                android:text="3 TRANSACTIONS"
                android:textColor="#2D6A4F"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_rounded_light_green" />
        </LinearLayout>

        <!-- RecyclerView (dynamic data) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHisaab"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="10dp"
            android:clipToPadding="false"
            android:paddingBottom="90dp"
            android:scrollbars="none" />

    </LinearLayout>

</LinearLayout>
