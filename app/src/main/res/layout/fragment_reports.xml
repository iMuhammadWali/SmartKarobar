<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reportsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E9F5EF">

    <!--    Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#2D6A4F">

        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_profile_avatar"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_rounded_light_green"
            android:padding="2dp" />

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="User"
            android:textColor="#E8F5EE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp" />

        <ImageView
            android:layout_width="80dp"
            android:layout_height="50dp"
            android:src="@drawable/img_app_logo"
            app:tint="@color/white" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/svOuter"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvReportsHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reports"
                android:textColor="#145A3B"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvReportsSubHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apne karobar ki taraqqi dekhein"
                android:textColor="#4B6A5B"
                android:textSize="13sp" />

            <!-- AI Summary -->
            <!-- Business Pulse AI Analyst -->
            <LinearLayout
                android:id="@+id/cardBusinessPulse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#1B4D38"
                android:orientation="vertical"
                android:paddingBottom="4dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_nav_selected"
                        android:gravity="center"
                        android:text="✦"
                        android:textColor="#D8F3DC"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Business Pulse"
                        android:textColor="#D8F3DC"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPulseBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_nav_selected"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:text="AI Analyst"
                        android:textColor="#9FE3C3"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Sentiment row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingBottom="8dp">

                    <View
                        android:id="@+id/vSentimentDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_pin_dot_filled"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/tvSentiment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Business health analyzing..."
                        android:textColor="#9FE3C3"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- AI Summary text (streaming) -->
                <TextView
                    android:id="@+id/tvAiSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:paddingHorizontal="14dp"
                    android:paddingBottom="10dp"
                    android:text="Soch raha hoon... ✦"
                    android:textColor="#B7DFC8"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp" />

                <!-- Chat history container -->

                <LinearLayout
                    android:id="@+id/llChatHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp" />

                <!-- Suggestion chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingHorizontal="14dp"
                    android:layout_marginTop="6dp">

                    <LinearLayout
                        android:id="@+id/llChips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />
                </HorizontalScrollView>

                <!-- Input row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etPulseInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_nav_selected"
                        android:hint="Apna sawaal poochein..."
                        android:textColor="#D8F3DC"
                        android:textColorHint="#80D8F3DC"
                        android:textSize="13sp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp"
                        android:inputType="text"
                        android:imeOptions="actionSend"
                        android:maxLines="1" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnPulseSend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Poochein"
                        android:textColor="#D8F3DC"
                        android:textSize="12sp"
                        android:background="@drawable/bg_nav_selected"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Weekly Sales Trend -->
            <LinearLayout
                android:id="@+id/cardWeeklyTrend"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Is Hafte Ki Bikri"
                            android:textColor="#1E5B3E"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weekly Sales Trend"
                            android:textColor="#8A8F94"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvWeeklySalesAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs. 0"
                        android:textColor="#1E5B3E"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChartWeeklySales"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="12dp"
                    android:minHeight="200dp"
                    android:background="#F7FAF8" />

            </LinearLayout>

            <!-- Profit Projection -->
            <LinearLayout
                android:id="@+id/cardProfitProjection"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_nav_selected"
                android:orientation="horizontal"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PROFIT PROJECTION"
                        android:textColor="#94D3B5"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProfitProjectionAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs. 0"
                        android:textColor="#9FE3C3"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProfitProjectionSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expected net gain this month"
                        android:textColor="#84C9AA"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/bg_reports_icon_circle"
                    android:padding="10dp"
                    android:src="@drawable/ic_trending_up"
                    android:tint="#D8F3DC" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="90dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>