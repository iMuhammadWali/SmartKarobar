<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#184C3A"
    android:gravity="center">

    <LinearLayout
        android:layout_width="340dp"
        android:layout_height="match_parent"
        android:layout_margin="12dp"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="40dp"
        android:paddingBottom="26dp">

        <!-- Logo -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="50dp" />
        <ImageView
            android:id="@+id/imgShield"
            android:layout_width="180dp"
            android:layout_height="70dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/img_app_logo"

            android:contentDescription="@string/app_name"
            app:tint="#D8F3DC" />

<!--        <TextView-->
<!--            android:id="@+id/tvAppName"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_gravity="center_horizontal"-->
<!--            android:layout_marginTop="14dp"-->
<!--            android:text="SmartKarobar"-->
<!--            android:textColor="#D8F3DC"-->
<!--            android:textSize="46sp"-->
<!--            android:textStyle="bold" />-->

        <Space
            android:layout_width="match_parent"
            android:layout_height="50dp" />

        <!-- Heading -->
        <TextView
            android:id="@+id/tvHeadingUrdu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apna number likhein"
            android:textColor="#D8F3DC"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubHeadingUrdu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="اپنا موبائل نمبر درج کریں"
            android:textColor="#9EC5B4"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Phone field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_signup_phone_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_phone"
                android:contentDescription="Phone"
                app:tint="#CFE9DD" />

            <TextView
                android:id="@+id/tvCountryCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="+92"
                android:textColor="#CFE9DD"
                android:textSize="17sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:background="@android:color/transparent"
                android:hint="300 1234567"
                android:inputType="phone"
                android:maxLength="10"
                android:textColor="#D8F3DC"
                android:textColorHint="#83A89A"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- OTP button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSendOtp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_signup_otp_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="OTP Bhejo"
            android:orientation="horizontal"
            android:textColor="@color/white">

        </androidx.appcompat.widget.AppCompatButton>

        <TextView
            android:id="@+id/tvTerms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="There are not privacy policy terms."
            android:textColor="#7FAE9B"
            android:textSize="11sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvBottomUrdu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="ہم آپ کے نمبر کی تصدیق کریں گے"
            android:textColor="#8EB9A7"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>